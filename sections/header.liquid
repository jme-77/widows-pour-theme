<header class="wp-header">
  <div class="wp-header__inner">
    <a href="{{ routes.root_url }}" class="wp-header__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | img_url: '320x' }}" alt="{{ shop.name }}" width="{{ section.settings.logo_max_width }}" loading="eager">
      {%- else -%}
        <span style="font-family:var(--wp-serif);font-style:italic;font-size:1.3rem;color:var(--wp-gold);">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <nav class="wp-header__nav">
      <ul>
        {%- for link in linklists[section.settings.menu].links -%}
          <li><a href="{{ link.url }}" {% if link.active %}class="is-active"{% endif %}>{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </nav>
    <div class="wp-header__actions">
      <a href="{{ routes.cart_url }}" class="wp-header__cart-icon" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <span class="wp-cart-count" style="display:none;background:var(--wp-gold);color:#000;border-radius:50%;width:16px;height:16px;font-size:9px;align-items:center;justify-content:center;position:absolute;top:-4px;right:-4px;font-family:var(--wp-sans);"></span>
      </a>
      <button class="wp-hamburger" aria-label="Menu" aria-expanded="false">
        <span class="wp-hamburger__line"></span>
        <span class="wp-hamburger__line"></span>
        <span class="wp-hamburger__line"></span>
      </button>
    </div>
  </div>
</header>
<div class="wp-mobile-nav">
  <button class="wp-mobile-nav__close" aria-label="Close">✕</button>
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}">{{ link.title }}</a>
  {%- endfor -%}
</div>
{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_max_width", "label": "Logo max width", "min": 80, "max": 300, "step": 4, "unit": "px", "default": 160 },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }
  ]
}
{% endschema %}

<section class="wp-newsletter">
  <div class="wp-newsletter__inner">
    <div class="wp-newsletter__flame">🕯️</div>
    <span class="wp-eyebrow">✧ {{ section.settings.eyebrow }} ✧</span>
    <h2 class="wp-newsletter__heading">{{ section.settings.heading }}</h2>
    <p class="wp-newsletter__sub">{{ section.settings.subheading }}</p>
    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="wp-newsletter__form">
        <input type="email" name="contact[email]" class="wp-newsletter__input" placeholder="{{ section.settings.placeholder }}" required aria-label="Email address">
        <button type="submit" class="wp-btn wp-newsletter__submit">{{ section.settings.btn_text }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <script>document.getElementById('newsletter-form').style.display='none';document.getElementById('newsletter-success').style.display='block';</script>
      {%- endif -%}
    {%- endform -%}
    <p id="newsletter-success" style="display:none;font-family:var(--wp-serif);font-style:italic;font-size:1.1rem;color:rgba(201,151,58,0.85)">You have joined the Widow's Circle. 🕯️</p>
    <p class="wp-newsletter__fine">{{ section.settings.fine_print }}</p>
  </div>
</section>
{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Widow's Circle" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Exclusive releases, candle rituals, and letters from the founder." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address..." },
    { "type": "text", "id": "btn_text", "label": "Button text", "default": "Light the Flame" },
    { "type": "text", "id": "fine_print", "label": "Fine print", "default": "10% off your first order. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}

<section style="background:var(--wp-black);min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:80px 40px">
  <div>
    <span style="font-family:var(--wp-serif);font-size:7rem;color:rgba(201,151,58,0.1);display:block;line-height:1">404</span>
    <span class="wp-eyebrow">✧ Page Not Found ✧</span>
    <h1 style="font-family:var(--wp-serif);font-weight:300;font-size:clamp(2rem,5vw,4rem);color:var(--wp-cream);margin-bottom:20px">The flame went out.</h1>
    <p style="font-family:var(--wp-serif);font-style:italic;color:rgba(240,230,207,0.55);margin-bottom:40px">This page no longer exists — but the light carries on.</p>

<section class="wp-values">
  <div style="text-align:center;margin-bottom:60px">
    <span class="wp-eyebrow">✧ {{ section.settings.eyebrow }} ✧</span>
    <h2 style="font-family:var(--wp-serif);font-weight:300;font-size:clamp(2rem,4vw,3rem);color:var(--wp-cream)">{{ section.settings.heading }}</h2>
    <div class="wp-divider"><span class="wp-divider__line"></span><span class="wp-divider__icon">🕯️</span><span class="wp-divider__line"></span></div>
  </div>
  <div class="wp-values__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'value' -%}
        <div class="wp-value-card wp-reveal" data-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="wp-value-card__icon">{{ block.settings.icon }}</div>
          <h3 class="wp-value-card__title">{{ block.settings.title }}</h3>
          <p class="wp-value-card__body">{{ block.settings.body }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if section.settings.show_cta -%}
    <div style="text-align:center;margin-top:60px">
      <a href="{{ section.settings.cta_url }}" class="wp-btn">{{ section.settings.cta_text }}</a>
    </div>
  {%- endif -%}
</section>
{% schema %}
{
  "name": "Values",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What We Believe" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Pour Behind the Pour" },
    { "type": "checkbox", "id": "show_cta", "label": "Show button", "default": true },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_url", "label": "Button link", "default": "/collections/all" }
  ],
  "blocks": [{
    "type": "value",
    "name": "Value Card",
    "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji or text symbol)", "default": "🕯️" },
      { "type": "text", "id": "title", "label": "Title", "default": "Grief is Sacred" },
      { "type": "textarea", "id": "body", "label": "Body text", "default": "We don't rush past grief. We sit with it, honor it, and pour it into something lasting." }
    ]
  }],
  "presets": [{
    "name": "Values",
    "blocks": [
      { "type": "value", "settings": { "icon": "🕯️", "title": "Grief is Sacred", "body": "We don't rush past grief. We sit with it, honor it, and pour it into something lasting." } },
      { "type": "value", "settings": { "icon": "✦", "title": "Love Is a Legacy", "body": "Every scent we create is designed to carry love forward — not erase it, but transform it." } },
      { "type": "value", "settings": { "icon": "⬥", "title": "Small Batch, Always", "body": "We will never scale past the ability to pour with intention. Every candle deserves our full attention." } }
    ]
  }]
}
{% endschema %}

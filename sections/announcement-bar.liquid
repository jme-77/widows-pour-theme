<div class="wp-announcement">
  <p>{{ section.settings.text }}</p>
</div>
{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Announcement text",
      "default": "✧ Built on Strength, Fire & Reinvention · Free shipping on orders over $75 ✧" }
  ]
}
{% endschema %}

<section class="wp-page-hero">
  <div class="wp-page-hero__bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '1600x' }}" alt="" loading="eager">
    {%- else -%}
      <img src="{{ 'candle-1.png' | asset_url }}" alt="">
    {%- endif -%}
    <div class="wp-page-hero__overlay"></div>
  </div>
  <div class="wp-page-hero__content">
    <span class="wp-eyebrow wp-fade-up">✧ {{ section.settings.eyebrow }} ✧</span>
    
    {% comment %} Dynamic logic for collection pages {% endcomment %}
    <h1 class="wp-page-hero__heading wp-fade-up-2">
      {%- if collection.title != blank -%}
        {{ collection.title }}
      {%- else -%}
        {{ section.settings.heading }}
      {%- endif -%}
    </h1>
    
    <div class="wp-divider wp-fade-up-3"><span class="wp-divider__line"></span><span class="wp-divider__icon">🕯️</span><span class="wp-divider__line"></span></div>
    
    <p class="wp-page-hero__sub wp-fade-up-3">
      {%- if collection.description != blank -%}
        {{ collection.description | strip_html | truncatewords: 20 }}
      {%- else -%}
        {{ section.settings.subheading }}
      {%- endif -%}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Est. Suffolk, Virginia" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Born from love, loss, and the sacred act of pouring grief into something that burns beautiful." }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
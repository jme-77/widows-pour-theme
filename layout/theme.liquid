<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="canonical" href="{{ canonical_url }}">
  
  {%- render 'meta-tags' -%}
  
  <title>{{ page_title }}{%- unless page_title contains shop.name %} — {{ shop.name }}{% endunless -%}</title>
  
  {{ content_for_header }}

  <!-- ✅ GOOGLE FONTS (FIXED + WORKING) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Quintessential&family=Tangerine:wght@400;700&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- ✅ YOUR STYLES -->
  <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'widows-pour.css' | asset_url }}">
</head>

<body class="wp-body template-{{ template.name }}">

  {% if template.name == 'index' %}
    {% render 'widows-pour-landing' %}
  {% endif %}

  {% sections 'header-group' %}
  
  <!-- ✅ FADE SYSTEM -->
  <main id="MainContent" class="wp-page-fade" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  <script src="{{ 'widows-pour.js' | asset_url }}" defer></script>
</body>
</html>